# Configura estas variáveis em: Vercel → Project → Settings → Environment Variables

# Chave gratuita do Google Gemini (AI Studio) — sem cartão de crédito.
# Cria em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo usado (default já é bom para este caso)
AGENT_MODEL=gemini-2.5-flash

# Supabase (memória persistente — opcional; sem isto, os agentes funcionam
# mas sem memória entre sessões)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Chave secreta para o endpoint de ingestão de conhecimento (RAG).
# Escolhe uma password forte qualquer — só tu (e eu, quando alimento a
# base) precisamos de a saber.
INGEST_SECRET=
