# Configura estas variáveis em: Vercel → Project → Settings → Environment Variables

# Chave da API Anthropic
ANTHROPIC_API_KEY=

# Modelos usados (router barato, agentes com mais qualidade)
AGENT_MODEL=claude-haiku-4-5-20251001
AGENT_EXEC_MODEL=claude-sonnet-5

# Supabase (memória persistente — opcional; sem isto, os agentes funcionam
# mas sem memória entre sessões)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
